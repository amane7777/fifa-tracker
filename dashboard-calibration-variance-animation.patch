       if (isSettled) runningActual += b.pnl || 0;
       runningExpected += expectedPnl(b);
+      runningVar += betVariance(b);
       aPts.push({ x: i + 1, y: runningActual });
       ePts.push({ x: i + 1, y: runningExpected });
+      sPts.push({ x: i + 1, sd: Math.sqrt(runningVar) });
