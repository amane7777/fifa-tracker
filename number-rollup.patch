+// Rolls a number from its previous value to a new one whenever `value`
+// changes, easing over ~700ms. `format` renders the interpolated number.
+function AnimatedNumber({ value, format, duration = 700 }) {
+  const [display, setDisplay] = useState(value);
+  const fromRef = React.useRef(value);
+  const rafRef = React.useRef(null);
+
+  React.useEffect(() => {
+    const from = fromRef.current;
+    const to = value;
+    if (from === to || Number.isNaN(from) || Number.isNaN(to)) {
+      setDisplay(to);
+      fromRef.current = to;
+      return;
+    }
+    const start = performance.now();
+    const tick = (now) => {
+      const t = Math.min(1, (now - start) / duration);
+      // easeOutCubic — fast start, gentle settle, reads as a natural roll-up.
+      const eased = 1 - Math.pow(1 - t, 3);
+      setDisplay(from + (to - from) * eased);
+      if (t < 1) {
+        rafRef.current = requestAnimationFrame(tick);
+      } else {
+        fromRef.current = to;
+      }
+    };
+    rafRef.current = requestAnimationFrame(tick);
+    return () => { if (rafRef.current) cancelAnimationFrame(rafRef.current); };
+  }, [value, duration]);
+
+  return <>{format(display)}</>;
+}
