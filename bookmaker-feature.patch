+// ── Bookmakers ────────────────────────────────────────────────────────────
+// Colours are approximations of each brand's palette, used only for a small
+// text/initial badge — not a reproduction of any logo. If you drop real logo
+// files into /public/logos/<key>.png (or .svg), BookmakerBadge will use them
+// automatically and only fall back to the coloured initials if the image
+// 404s, so no code change is needed once you add the files.
+const BOOKMAKERS = [
+  { key: "sportsbet", label: "Sportsbet", initials: "SB", bg: "#002B5C", fg: "#FFD100" },
+  { key: "tab", label: "TAB", initials: "TAB", bg: "#00843D", fg: "#FFFFFF" },
+  { key: "betr", label: "BETR", initials: "BR", bg: "#111111", fg: "#FF3B30" },
+  { key: "bet365", label: "Bet365", initials: "365", bg: "#046A38", fg: "#FFE500" },
+  { key: "ladbrokes", label: "Ladbrokes", initials: "LB", bg: "#C8102E", fg: "#FFFFFF" },
+  { key: "neds", label: "Neds", initials: "ND", bg: "#FFDD00", fg: "#111111" },
+  { key: "pointsbet", label: "PointsBet", initials: "PB", bg: "#E30613", fg: "#FFFFFF" },
+  { key: "unibet", label: "Unibet", initials: "UB", bg: "#147B4F", fg: "#FFFFFF" },
+];
+const BOOKMAKER_MAP = Object.fromEntries(BOOKMAKERS.map(b => [b.key, b]));
+
+// Resolves a stored bookmaker value (key or free-typed label) to a display
+// entry, falling back to a generic grey badge with its first letters.
+function resolveBookmaker(value) {
+  if (!value) return null;
+  const key = value.trim().toLowerCase().replace(/[^a-z0-9]/g, "");
+  if (BOOKMAKER_MAP[key]) return BOOKMAKER_MAP[key];
+  const byLabel = BOOKMAKERS.find(b => b.label.toLowerCase() === value.trim().toLowerCase());
+  if (byLabel) return byLabel;
+  return { key, label: value, initials: value.trim().slice(0, 3).toUpperCase(), bg: "var(--bg-panel-2)", fg: "var(--text-muted)" };
+}
+
+function BookmakerBadge({ value, size = 20 }) {
+  const bm = resolveBookmaker(value);
+  const [imgFailed, setImgFailed] = useState(false);
+  if (!bm) return null;
+  if (!imgFailed) {
+    return (
+      <img
+        src={`/logos/${bm.key}.png`}
+        alt={bm.label}
+        title={bm.label}
+        onError={() => setImgFailed(true)}
+        style={{ width: size, height: size, borderRadius: 5, objectFit: "contain", background: "var(--bg-panel-2)", flexShrink: 0 }}
+      />
+    );
+  }
+  return (
+    <span title={bm.label} style={{
+      display: "inline-flex", alignItems: "center", justifyContent: "center",
+      width: size, height: size, borderRadius: 5, background: bm.bg, color: bm.fg,
+      fontSize: size * 0.36, fontWeight: 800, fontFamily: "var(--ui)", letterSpacing: "-0.02em",
+      flexShrink: 0
+    }}>
+      {bm.initials}
+    </span>
+  );
+}
